{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",

    "target": "ESNext",
    "lib": ["ESNext"],

    "module": "ESNext",
    "moduleResolution": "bundler",

    "types": ["node"],

    "skipLibCheck": true,
    "noEmit": true,

    "strict": true,

    "verbatimModuleSyntax": true,
    "moduleDetection": "force",

    "forceConsistentCasingInFileNames": true
  },
  "include": ["vite.config.ts"]
}