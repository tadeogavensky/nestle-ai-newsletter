  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const mockHeaders = [",
          "  { key: 'Authorization', value: `Bearer ${pm.collectionVariables.get('bearerToken')}` },",
          "  { key: 'x-user-id', value: pm.collectionVariables.get('mockUserId') },",
          "  { key: 'x-user-role', value: pm.collectionVariables.get('mockUserRole') },",
          "  { key: 'x-area', value: pm.collectionVariables.get('mockArea') }",
          "];",
          "",
          "for (const header of mockHeaders) {",
          "  pm.request.headers.upsert(header);",
          "}"
        ]
      }
    }
  ],
